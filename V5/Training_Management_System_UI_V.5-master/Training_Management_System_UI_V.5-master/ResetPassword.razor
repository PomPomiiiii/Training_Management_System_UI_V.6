@page "/reset-password"
@inject NavigationManager Nav

<PageTitle>Reset Password | SitesPhil Training</PageTitle>

<div class="background-overlay"></div>
<div class="scanlines"></div>

<div class="login-container">
    <div class="login-card">

        <div class="brand-header">
            <div class="brand-logo">
                <div class="logo-icon">
                    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <polygon points="20,2 38,12 38,28 20,38 2,28 2,12" stroke="#E0251A" stroke-width="2" fill="none" />
                        <polygon points="20,8 32,15 32,25 20,32 8,25 8,15" fill="#E0251A" opacity="0.3" />
                        <line x1="20" y1="2" x2="20" y2="38" stroke="#E0251A" stroke-width="1" opacity="0.5" />
                        <line x1="2" y1="20" x2="38" y2="20" stroke="#E0251A" stroke-width="1" opacity="0.5" />
                    </svg>
                </div>
                <span class="logo-text">SITESPHIL</span>
            </div>
            <div class="brand-divider"></div>

            @if (!passwordReset)
            {
                <div class="title-row">
                    <div class="back-icon-btn" @onclick="GoBack" title="Back to Login">
                        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                    <div>
                        <h1 class="brand-title">Reset Password</h1>
                        <p class="brand-subtitle">Enter your new password below</p>
                    </div>
                </div>
            }
            else
            {
                <h1 class="brand-title">Password Updated</h1>
                <p class="brand-subtitle">Your password has been reset</p>
            }
        </div>

        @if (!passwordReset)
        {
            <div class="info-banner">
                <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" />
                    <path d="M10 6v4M10 14h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
                <span>Password must be at least 8 characters and contain letters and numbers.</span>
            </div>

            <div class="input-group">
                <label for="new-password">New Password</label>
                <div class="input-wrapper">
                    <span class="input-icon">
                        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="4" y="9" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                            <path d="M7 9V6a3 3 0 016 0v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                    </span>
                    <input id="new-password"
                           type="@(showNewPassword ? "text" : "password")"
                           @bind="newPassword"
                           @bind:event="oninput"
                           placeholder="Enter new password"
                           class="form-input"
                           disabled="@isLoading" />
                    <button type="button" class="toggle-pw-btn" @onclick="() => showNewPassword = !showNewPassword" tabindex="-1">
                        @if (showNewPassword)
                        {
                            <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M3 10s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5" />
                                <circle cx="10" cy="10" r="2" stroke="currentColor" stroke-width="1.5" />
                                <path d="M3 3l14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                            </svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M3 10s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5" />
                                <circle cx="10" cy="10" r="2" stroke="currentColor" stroke-width="1.5" />
                            </svg>
                        }
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(newPasswordValidation))
                {
                    <span class="validation-msg">@newPasswordValidation</span>
                }
            </div>

            <div class="input-group">
                <label for="confirm-password">Confirm Password</label>
                <div class="input-wrapper">
                    <span class="input-icon">
                        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="4" y="9" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                            <path d="M7 9V6a3 3 0 016 0v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                    </span>
                    <input id="confirm-password"
                           type="@(showConfirmPassword ? "text" : "password")"
                           @bind="confirmPassword"
                           @bind:event="oninput"
                           placeholder="Confirm new password"
                           class="form-input"
                           disabled="@isLoading" />
                    <button type="button" class="toggle-pw-btn" @onclick="() => showConfirmPassword = !showConfirmPassword" tabindex="-1">
                        @if (showConfirmPassword)
                        {
                            <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M3 10s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5" />
                                <circle cx="10" cy="10" r="2" stroke="currentColor" stroke-width="1.5" />
                                <path d="M3 3l14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                            </svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M3 10s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5" />
                                <circle cx="10" cy="10" r="2" stroke="currentColor" stroke-width="1.5" />
                            </svg>
                        }
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(confirmPasswordValidation))
                {
                    <span class="validation-msg">@confirmPasswordValidation</span>
                }
            </div>

            <!-- Password strength indicator -->
            @if (!string.IsNullOrEmpty(newPassword))
            {
                <div class="strength-wrap">
                    <div class="strength-bars">
                        <div class="strength-bar @(PasswordStrength >= 1 ? "bar-" + StrengthClass : "")"></div>
                        <div class="strength-bar @(PasswordStrength >= 2 ? "bar-" + StrengthClass : "")"></div>
                        <div class="strength-bar @(PasswordStrength >= 3 ? "bar-" + StrengthClass : "")"></div>
                        <div class="strength-bar @(PasswordStrength >= 4 ? "bar-" + StrengthClass : "")"></div>
                    </div>
                    <span class="strength-label @("label-" + StrengthClass)">@StrengthLabel</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-banner">
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" />
                        <path d="M10 6v4M10 14h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                    @errorMessage
                </div>
            }

            <button type="button" class="login-btn" @onclick="HandleResetPassword" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner"></span>
                    <span>Updating Password...</span>
                }
                else
                {
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4 10l4 4 8-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>SET NEW PASSWORD</span>
                }
            </button>

            <div class="back-link-row">
                <a href="/login" class="back-link">
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    Back to Login
                </a>
            </div>
        }
        else
        {
            <div class="success-state">
                <div class="success-icon-wrap">
                    <div class="success-ring"></div>
                    <svg class="success-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="20" cy="20" r="18" stroke="#E0251A" stroke-width="1.5" opacity="0.3" />
                        <path d="M6 20l9 9L34 11" stroke="#E0251A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>

                <p class="success-msg">
                    Your password has been updated.<br />
                    <strong>You can now log in with your new password.</strong>
                </p>

                <p class="success-note">
                    For security, all other sessions have been <span class="highlight">signed out</span>.
                </p>

                <button type="button" class="login-btn" @onclick='() => Nav.NavigateTo("/login")'>
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 10h14M10 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>GO TO LOGIN</span>
                </button>
            </div>
        }

        <div class="card-footer">
            <span class="footer-tag">SECURE ACCESS</span>
            <span class="footer-divider">•</span>
            <span class="footer-tag">SITESPHIL &copy; @DateTime.Now.Year</span>
        </div>
    </div>
</div>

@code {
    [Parameter][SupplyParameterFromQuery] public string? Token { get; set; }

    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private string newPasswordValidation = string.Empty;
    private string confirmPasswordValidation = string.Empty;
    private string errorMessage = string.Empty;
    private bool isLoading = false;
    private bool passwordReset = false;
    private bool showNewPassword = false;
    private bool showConfirmPassword = false;

    private int PasswordStrength
    {
        get
        {
            if (string.IsNullOrEmpty(newPassword)) return 0;
            int score = 0;
            if (newPassword.Length >= 8) score++;
            if (newPassword.Any(char.IsUpper)) score++;
            if (newPassword.Any(char.IsDigit)) score++;
            if (newPassword.Any(c => !char.IsLetterOrDigit(c))) score++;
            return score;
        }
    }

    private string StrengthLabel => PasswordStrength switch
    {
        1 => "Weak",
        2 => "Fair",
        3 => "Good",
        4 => "Strong",
        _ => ""
    };

    private string StrengthClass => PasswordStrength switch
    {
        1 => "weak",
        2 => "fair",
        3 => "good",
        4 => "strong",
        _ => ""
    };

    private async Task HandleResetPassword()
    {
        newPasswordValidation = string.Empty;
        confirmPasswordValidation = string.Empty;
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(newPassword))
        {
            newPasswordValidation = "New password is required.";
            return;
        }

        if (newPassword.Length < 8)
        {
            newPasswordValidation = "Password must be at least 8 characters.";
            return;
        }

        if (!newPassword.Any(char.IsDigit))
        {
            newPasswordValidation = "Password must contain at least one number.";
            return;
        }

        if (string.IsNullOrWhiteSpace(confirmPassword))
        {
            confirmPasswordValidation = "Please confirm your password.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            confirmPasswordValidation = "Passwords do not match.";
            return;
        }

        isLoading = true;
        StateHasChanged();

        // Simulate API call — replace with actual service call
        await Task.Delay(1800);

        // TODO: var result = await AuthService.ResetPasswordAsync(Token, newPassword);
        // if (!result.IsSuccess) { errorMessage = result.Message; isLoading = false; return; }

        isLoading = false;
        passwordReset = true;
        StateHasChanged();
    }

    private void GoBack() => Nav.NavigateTo("/forgot-password");
}