@page "/forgot-password"
@inject NavigationManager Nav

<PageTitle>Forgot Password | SitesPhil Training</PageTitle>

<div class="background-overlay"></div>
<div class="scanlines"></div>

<div class="login-container">
    <div class="login-card">

        <div class="brand-header">
            <div class="brand-logo">
                <div class="logo-icon">
                    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <polygon points="20,2 38,12 38,28 20,38 2,28 2,12" stroke="#E0251A" stroke-width="2" fill="none" />
                        <polygon points="20,8 32,15 32,25 20,32 8,25 8,15" fill="#E0251A" opacity="0.3" />
                        <line x1="20" y1="2" x2="20" y2="38" stroke="#E0251A" stroke-width="1" opacity="0.5" />
                        <line x1="2" y1="20" x2="38" y2="20" stroke="#E0251A" stroke-width="1" opacity="0.5" />
                    </svg>
                </div>
                <span class="logo-text">SITESPHIL</span>
            </div>
            <div class="brand-divider"></div>

            @if (!emailSent)
            {
                <div class="title-row">
                    <div class="back-icon-btn" @onclick="GoBack" title="Back to Login">
                        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                    <div>
                        <h1 class="brand-title">Forgot Password</h1>
                        <p class="brand-subtitle">Enter your email to reset access</p>
                    </div>
                </div>
            }
            else
            {
                <h1 class="brand-title">Check Your Email</h1>
                <p class="brand-subtitle">Reset link sent successfully</p>
            }
        </div>

        @if (!emailSent)
        {
            <div class="info-banner">
                <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" />
                    <path d="M10 6v4M10 14h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
                <span>We'll send a password reset link to your registered email address.</span>
            </div>

            <div class="input-group">
                <label for="email">Email Address</label>
                <div class="input-wrapper">
                    <span class="input-icon">
                        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 5a2 2 0 012-2h10a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V5z" stroke="currentColor" stroke-width="1.5" />
                            <path d="M3 7l7 5 7-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                    </span>
                    <input id="email"
                           @bind="emailAddress"
                           @bind:event="oninput"
                           type="email"
                           placeholder="Enter your registered email"
                           class="form-input"
                           disabled="@isLoading" />
                </div>
                @if (!string.IsNullOrEmpty(validationMessage))
                {
                    <span class="validation-msg">@validationMessage</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-banner">
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" />
                        <path d="M10 6v4M10 14h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                    @errorMessage
                </div>
            }

            <button type="button" class="login-btn" @onclick="HandleSendReset" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner"></span>
                    <span>Sending Reset Link...</span>
                }
                else
                {
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M2 10l16-7-7 16-2-6-7-3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>SEND RESET LINK</span>
                }
            </button>

            <div class="back-link-row">
                <a href="/login" class="back-link">
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    Back to Login
                </a>
            </div>
        }
        else
        {
            <div class="success-state">
                <div class="success-icon-wrap">
                    <div class="success-ring"></div>
                    <svg class="success-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="20" cy="20" r="18" stroke="#E0251A" stroke-width="1.5" opacity="0.3" />
                        <path d="M6 20l9 9L34 11" stroke="#E0251A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>

                <p class="success-msg">
                    A reset link has been sent to<br />
                    <strong>@emailAddress</strong>
                </p>

                <p class="success-note">
                    Check your inbox and follow the instructions. The link expires in <span class="highlight">30 minutes</span>.
                </p>

                <button type="button" class="login-btn" @onclick="HandleResend" disabled="@resendCooldown">
                    @if (resendCooldown)
                    {
                        <span>Resend available in @cooldownSeconds s</span>
                    }
                    else
                    {
                        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M4 10a6 6 0 1 1 1.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M4 14V10H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <span>RESEND EMAIL</span>
                    }
                </button>

                <div class="back-link-row">
                    <a href="/login" class="back-link">
                        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        Back to Login
                    </a>
                </div>
            </div>
        }

        <div class="card-footer">
            <span class="footer-tag">SECURE ACCESS</span>
            <span class="footer-divider">•</span>
            <span class="footer-tag">SITESPHIL &copy; @DateTime.Now.Year</span>
        </div>
    </div>
</div>

@code {
    private string emailAddress = string.Empty;
    private string validationMessage = string.Empty;
    private string errorMessage = string.Empty;
    private bool isLoading = false;
    private bool emailSent = false;
    private bool resendCooldown = false;
    private int cooldownSeconds = 60;
    private System.Threading.CancellationTokenSource? _cts;

    private async Task HandleSendReset()
    {
        validationMessage = string.Empty;
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(emailAddress))
        {
            validationMessage = "Email is required.";
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(emailAddress, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
        {
            validationMessage = "Enter a valid email address.";
            return;
        }

        isLoading = true;
        StateHasChanged();

        // Simulate API call — replace with actual service call
        await Task.Delay(1800);

        // TODO: var result = await AuthService.SendPasswordResetAsync(emailAddress);
        // if (!result.IsSuccess) { errorMessage = result.Message; isLoading = false; return; }

        isLoading = false;
        emailSent = true;
        StartResendCooldown();
        StateHasChanged();
    }

    private async Task HandleResend()
    {
        if (resendCooldown) return;
        isLoading = true;
        StateHasChanged();

        await Task.Delay(1500);

        isLoading = false;
        StartResendCooldown();
        StateHasChanged();
    }

    private void StartResendCooldown()
    {
        resendCooldown = true;
        cooldownSeconds = 60;
        _cts?.Cancel();
        _cts = new System.Threading.CancellationTokenSource();
        var token = _cts.Token;

        _ = Task.Run(async () =>
        {
            while (cooldownSeconds > 0 && !token.IsCancellationRequested)
            {
                await Task.Delay(1000, token).ContinueWith(_ => { });
                cooldownSeconds--;
                await InvokeAsync(StateHasChanged);
            }
            if (!token.IsCancellationRequested)
            {
                resendCooldown = false;
                await InvokeAsync(StateHasChanged);
            }
        }, token);
    }

    private void GoBack() => Nav.NavigateTo("/login");

    public void Dispose() => _cts?.Cancel();
}