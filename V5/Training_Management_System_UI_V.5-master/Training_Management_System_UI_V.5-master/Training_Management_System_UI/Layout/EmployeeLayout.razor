@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="emp-shell">
    <div class="scanlines"></div>
    <div class="bg-glow"></div>

    <!-- SIDEBAR -->
    <aside class="emp-sidebar @(sidebarCollapsed ? "collapsed" : "")">
        <div class="sidebar-brand">
            <div class="brand-mark">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
            </div>
            @if (!sidebarCollapsed)
            {
                <div class="brand-text">
                    <span class="brand-name">SitesPhil</span>
                    <span class="brand-sub">Training Portal</span>
                </div>
            }
        </div>

        <button class="collapse-btn" @onclick="ToggleSidebar" title="@(sidebarCollapsed ? "Expand" : "Collapse")">
            <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                @if (sidebarCollapsed)
                {
                    <path d="M7 5l6 5-6 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                }
                else
                {
                    <path d="M13 5l-6 5 6 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                }
            </svg>
        </button>

        <div class="sidebar-divider"></div>

        <div class="nav-section-label">@(!sidebarCollapsed ? "Navigation" : "")</div>

        <nav class="sidebar-nav">
            <NavLink href="/employee/dashboard" class="nav-item" ActiveClass="nav-item-active" Match="NavLinkMatch.All">
                <span class="nav-icon">
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="2" y="2" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                        <rect x="11" y="2" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                        <rect x="2" y="11" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                        <rect x="11" y="11" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                    </svg>
                </span>
                @if (!sidebarCollapsed)
                {
                    <span class="nav-label">Dashboard</span>
                }
            </NavLink>

            <NavLink href="/employee/trainings" class="nav-item" ActiveClass="nav-item-active">
                <span class="nav-icon">
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4 4h12v10a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" stroke="currentColor" stroke-width="1.5" />
                        <path d="M8 4V2M12 4V2M4 8h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                </span>
                @if (!sidebarCollapsed)
                {
                    <span class="nav-label">My Trainings</span>
                }
            </NavLink>
        </nav>

        <!-- User Profile -->
        <div class="sidebar-footer">
            <div class="sidebar-divider"></div>
            @if (!sidebarCollapsed)
            {
                <div class="user-profile">
                    <div class="user-avatar-sm">
                        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5" />
                            <path d="M3 17c0-3.866 3.134-6 7-6s7 2.134 7 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                    </div>
                    <div class="user-info">
                        <span class="user-name-sm">Employee</span>
                        <span class="user-role-sm">Employee Portal</span>
                    </div>
                </div>
            }
            <button class="nav-item logout-btn" @onclick="HandleLogout" title="Sign Out">
                <span class="nav-icon">
                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M13 10H3M10 7l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M8 5H5a2 2 0 00-2 2v6a2 2 0 002 2h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                </span>
                @if (!sidebarCollapsed)
                {
                    <span class="nav-label">Sign Out</span>
                }
            </button>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="emp-main">
        <header class="topbar">
            <div class="topbar-left">
                <div class="breadcrumb-indicator">
                    <span class="bc-dot"></span>
                    <span class="bc-text">TMS Employee Portal</span>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-clock">@currentTime</div>
                <span class="topbar-date">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</span>
            </div>
        </header>

        <div class="page-area">
            @Body
        </div>
    </main>
</div>

@code {
    private bool sidebarCollapsed = false;
    private string currentTime = string.Empty;
    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        UpdateTime();
        _timer = new System.Threading.Timer(_ =>
        {
            UpdateTime();
            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    private void UpdateTime()
    {
        currentTime = DateTime.Now.ToString("HH:mm:ss");
    }

    private void ToggleSidebar()
    {
        sidebarCollapsed = !sidebarCollapsed;
    }

    private void HandleLogout()
    {
        Nav.NavigateTo("/login");
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
