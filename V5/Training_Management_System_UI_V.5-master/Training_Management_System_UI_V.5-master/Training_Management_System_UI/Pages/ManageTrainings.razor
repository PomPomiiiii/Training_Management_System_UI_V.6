@inject TrainingService TrainingService
@inject NavigationManager Nav
@using Training_Management_System_UI.Models.Training
@using Training_Management_System_UI.Services

@page "/admin/manage-trainings"
@layout AdminLayout

<PageTitle>Manage Trainings | SitesPhil TMS</PageTitle>

<div class="page-wrapper">

    <div class="page-header">
        <div class="header-left">
            <div class="page-eyebrow">
                <span class="eyebrow-line"></span>
                <span>TRAININGS</span>
            </div>
            <h1 class="page-title">Manage Trainings</h1>
            <p class="page-subtitle">View, edit and remove programs</p>
        </div>
        <a href="/admin/create-training" class="btn-primary">
            <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" />
                <path d="M10 6v8M6 10h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            </svg>
            Create New
        </a>
    </div>

    @if (isLoading)
    {
        <p style="color: var(--clr-text-ghost); padding: 20px;">Loading...</p>
    }
    else
    {
        <!-- Toolbar -->
        <div class="toolbar">
            <div class="search-wrapper">
                <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5" />
                    <path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
                <input type="text" class="search-input" placeholder="Search trainings..."
                       @bind="searchTerm" @bind:event="oninput" />
            </div>
            <select class="filter-select" @bind="selectedStatus">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="disabled">Disabled</option>
            </select>
            <div class="result-count">
                <span>@FilteredTrainings.Count() result@(FilteredTrainings.Count() == 1 ? "" : "s")</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-banner" style="margin-bottom: 12px;">@errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="success-banner" style="margin-bottom: 12px;">@successMessage</div>
        }

        <!-- Table -->
        <div class="table-card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="th-check">
                            <div class="checkbox-wrap">
                                <input type="checkbox" @bind="allSelected" @bind:after="ToggleAll" />
                            </div>
                        </th>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Duration</th>
                        <th>Created</th>
                        <th>Materials</th>
                        <th>Attendees</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in FilteredTrainings)
                    {
                        var rowId = t.TrainingId;
                        <tr class="table-row clickable-row @(selectedIds.Contains(t.TrainingId) ? "row-selected" : "")"
                            @onclick="() => OpenTraining(rowId)">
                            <td class="td-check" @onclick:stopPropagation="true">
                                <div class="checkbox-wrap">
                                    <input type="checkbox"
                                           checked="@selectedIds.Contains(t.TrainingId)"
                                           @onchange="() => ToggleRow(t.TrainingId)" />
                                </div>
                            </td>
                            <td>
                                <div class="title-cell">
                                    <span class="title-dot @(t.Disabled ? "dot-disabled" : "")"></span>
                                    <span class="td-title">@t.Title</span>
                                    <svg class="row-open-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </div>
                            </td>
                            <td class="td-desc">
                                <span class="desc-truncate">@(string.IsNullOrEmpty(t.Description) ? "—" : t.Description)</span>
                            </td>
                            <td>
                                <span class="duration-badge">
                                    @t.TrainingDurationInDays day@(t.TrainingDurationInDays == 1 ? "" : "s")
                                </span>
                            </td>
                            <td class="td-muted">@t.CreatedAt.ToString("MMM d, yyyy")</td>
                            <td>
                                <span class="count-badge materials">
                                    <svg viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" width="11" height="11">
                                        <rect x="1" y="2" width="9" height="11" rx="1" stroke="currentColor" stroke-width="1.2" />
                                        <path d="M4 7h4M4 9.5h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                                        <path d="M5 1h6a1 1 0 011 1v10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                                    </svg>
                                    @t.MaterialResponse.Count
                                </span>
                            </td>
                            <td>
                                <span class="count-badge attendees">
                                    <svg viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" width="11" height="11">
                                        <circle cx="5" cy="4" r="2.5" stroke="currentColor" stroke-width="1.2" />
                                        <path d="M1 12c0-2.761 1.79-4 4-4s4 1.239 4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                                        <path d="M10 6.5v3M11.5 8H8.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                                    </svg>
                                    @t.AttendeeResponse.Count
                                </span>
                            </td>
                            <td>
                                <span class="status-chip @(t.Disabled ? "chip-disabled" : "chip-active")">
                                    <span class="chip-dot"></span>
                                    @(t.Disabled ? "Disabled" : "Active")
                                </span>
                            </td>
                            <td @onclick:stopPropagation="true">
                                <div class="row-actions">
                                    <button class="btn-action btn-open" title="View Details"
                                            @onclick="() => OpenTraining(t.TrainingId)">
                                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M8 3C4.5 3 2 8 2 8s2.5 5 6 5 6-5 6-5-2.5-5-6-5z" stroke="currentColor" stroke-width="1.3" />
                                            <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.3" />
                                        </svg>
                                    </button>
                                    <button class="btn-action btn-toggle" title="@(t.Disabled ? "Enable" : "Disable")"
                                            @onclick="() => ToggleDisabled(t.TrainingId)">
                                        @if (t.Disabled)
                                        {
                                            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3" />
                                                <path d="M8 5v6M5 8h6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                                            </svg>
                                        }
                                        else
                                        {
                                            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3" />
                                                <path d="M5.5 8h5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                                            </svg>
                                        }
                                    </button>
                                    <button class="btn-action btn-delete" title="Delete"
                                            @onclick="() => DeleteTraining(t.TrainingId)">
                                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M2 4h12M5 4V2h6v2M6 7v5M10 7v5M3 4l1 10h8l1-10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!FilteredTrainings.Any())
                    {
                        <tr>
                            <td colspan="9" class="empty-row">
                                <div class="empty-state">
                                    <span>No trainings match your filters.</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Bulk action bar -->
            @if (selectedIds.Any())
            {
                <div class="bulk-bar">
                    <span class="bulk-count">@selectedIds.Count selected</span>
                    <button class="bulk-btn bulk-danger" @onclick="DeleteSelected">
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M2 4h12M5 4V2h6v2M6 7v5M10 7v5M3 4l1 10h8l1-10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        Delete Selected
                    </button>
                    <button class="bulk-btn" @onclick="() => selectedIds.Clear()">Clear Selection</button>
                </div>
            }
        </div>
    }
</div>

@code {
    private string searchTerm = string.Empty;
    private string selectedStatus = string.Empty;
    private bool allSelected = false;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private HashSet<Guid> selectedIds = new();
    private List<TrainingResponse> trainings = new();

    protected override async Task OnInitializedAsync()
    {
        trainings = await TrainingService.GetAllTrainingsAsync();
        isLoading = false;
    }

    private void OpenTraining(Guid id)
    {
        Nav.NavigateTo($"/admin/trainings/{id}");
    }

    private IEnumerable<TrainingResponse> FilteredTrainings => trainings
        .Where(t => string.IsNullOrEmpty(searchTerm) ||
            t.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            t.Description.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(t => selectedStatus switch
        {
            "active" => !t.Disabled,
            "disabled" => t.Disabled,
            _ => true
        });

    private async Task DeleteTraining(Guid id)
    {
        var (success, message) = await TrainingService.DeleteTrainingAsync(id);
        if (success)
        {
            trainings.RemoveAll(t => t.TrainingId == id);
            selectedIds.Remove(id);
            successMessage = "Training deleted successfully!";
            errorMessage = string.Empty;
        }
        else
        {
            errorMessage = $"Failed to delete: {message}";
        }
    }

    private async Task ToggleDisabled(Guid id)
    {
        var training = trainings.FirstOrDefault(t => t.TrainingId == id);
        if (training is null) return;

        var (success, message) = await TrainingService.ToggleDisabledAsync(id, !training.Disabled);
        if (success)
        {
            training.Disabled = !training.Disabled;
            successMessage = $"Training {(training.Disabled ? "disabled" : "enabled")} successfully!";
            errorMessage = string.Empty;
        }
        else
        {
            errorMessage = $"Failed: {message}";
        }
    }

    private async Task DeleteSelected()
    {
        foreach (var id in selectedIds.ToList())
        {
            var (success, _) = await TrainingService.DeleteTrainingAsync(id);
            if (success)
                trainings.RemoveAll(t => t.TrainingId == id);
        }
        selectedIds.Clear();
        allSelected = false;
        successMessage = "Selected trainings deleted!";
    }

    private void ToggleRow(Guid id)
    {
        if (!selectedIds.Remove(id)) selectedIds.Add(id);
    }

    private void ToggleAll()
    {
        if (allSelected)
            foreach (var t in FilteredTrainings) selectedIds.Add(t.TrainingId);
        else
            selectedIds.Clear();
    }
}
