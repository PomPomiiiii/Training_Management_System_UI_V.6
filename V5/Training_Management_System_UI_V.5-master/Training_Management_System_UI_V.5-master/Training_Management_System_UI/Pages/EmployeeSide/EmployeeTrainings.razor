@page "/employee/trainings"
@layout EmployeeLayout

<PageTitle>My Trainings | SitesPhil TMS</PageTitle>

<div class="page-wrapper">

    <div class="page-header">
        <div class="header-left">
            <div class="page-eyebrow">
                <span class="eyebrow-line"></span>
                <span>TRAININGS</span>
            </div>
            <h1 class="page-title">My Trainings</h1>
            <p class="page-subtitle">All programs you are enrolled in</p>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="toolbar">
        <div class="search-wrapper">
            <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5" />
                <path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            </svg>
            <input type="text" class="search-input" placeholder="Search trainings..."
                   @bind="searchTerm" @bind:event="oninput" />
        </div>
        <div class="result-count">
            <span>@FilteredTrainings.Count() result@(FilteredTrainings.Count() == 1 ? "" : "s")</span>
        </div>
    </div>

    <!-- Training Cards Grid -->
    @if (!FilteredTrainings.Any())
    {
        <div class="empty-state">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 8h24v20a4 4 0 01-4 4H12a4 4 0 01-4-4V8z" stroke="currentColor" stroke-width="1.5" />
                <path d="M14 8V6M26 8V6M8 16h24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            </svg>
            <p>No trainings found matching your search.</p>
        </div>
    }
    else
    {
        <div class="trainings-grid">
            @foreach (var t in FilteredTrainings)
            {
                <a href="/employee/trainings/@t.TrainingId" class="training-card">
                    <!-- Card accent bar -->
                    <div class="card-top-bar"></div>

                    <div class="card-header">
                        <div class="card-title-row">
                            <span class="card-dot"></span>
                            <h3 class="card-title">@t.Title</h3>
                        </div>
                        <span class="duration-badge">
                            @t.TrainingDurationInDays day@(t.TrainingDurationInDays == 1 ? "" : "s")
                        </span>
                    </div>

                    <p class="card-desc">@(string.IsNullOrWhiteSpace(t.Description) ? "No description provided." : t.Description)</p>

                    <div class="card-footer">
                        <div class="card-badges">
                            <span class="count-badge materials">
                                <svg viewBox="0 0 12 12" fill="none">
                                    <rect x="1.5" y="2" width="9" height="9" rx="1" stroke="currentColor" stroke-width="1.2" />
                                    <path d="M4 5.5h4M4 7.5h2.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                                </svg>
                                @t.MaterialCount material@(t.MaterialCount == 1 ? "" : "s")
                            </span>
                            <span class="count-badge attendees">
                                <svg viewBox="0 0 12 12" fill="none">
                                    <circle cx="5" cy="4" r="2" stroke="currentColor" stroke-width="1.2" />
                                    <path d="M1 10c0-2 1.8-3 4-3s4 1 4 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                                </svg>
                                @t.AttendeeCount attendee@(t.AttendeeCount == 1 ? "" : "s")
                            </span>
                        </div>
                        <span class="card-date">@t.CreatedAt.ToString("MMM d, yyyy")</span>
                    </div>

                    <div class="card-cta">
                        <span>View Details</span>
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                </a>
            }
        </div>
    }

</div>

@code {
    private string searchTerm = string.Empty;

    private IEnumerable<TrainingItem> FilteredTrainings =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? trainings
            : trainings.Where(t =>
                t.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                t.Description.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    // ERD: Training entity fields (active / non-disabled trainings the employee is enrolled in)
    private List<TrainingItem> trainings = new()
    {
        new()
        {
            TrainingId = 1, Title = "Workplace Safety Orientation",
            Description = "Fundamental safety practices and procedures for all site personnel.",
            TrainingDurationInDays = 1, MaterialCount = 4, AttendeeCount = 12,
            CreatedAt = new DateTime(2025, 1, 10)
        },
        new()
        {
            TrainingId = 2, Title = "Fire Safety & Emergency Response",
            Description = "Covers fire hazard identification, emergency protocols, and evacuation procedures.",
            TrainingDurationInDays = 2, MaterialCount = 3, AttendeeCount = 18,
            CreatedAt = new DateTime(2025, 2, 5)
        },
        new()
        {
            TrainingId = 3, Title = "Construction Site Protocols",
            Description = "In-depth walkthrough of on-site regulations, PPE requirements, and safety signage.",
            TrainingDurationInDays = 3, MaterialCount = 6, AttendeeCount = 10,
            CreatedAt = new DateTime(2025, 3, 15)
        },
        new()
        {
            TrainingId = 4, Title = "Electrical Safety Awareness",
            Description = "Identifying electrical hazards, lockout/tagout procedures, and safe work practices.",
            TrainingDurationInDays = 1, MaterialCount = 2, AttendeeCount = 8,
            CreatedAt = new DateTime(2025, 4, 2)
        },
    };

    private class TrainingItem
    {
        public int TrainingId { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public int TrainingDurationInDays { get; set; }
        public int MaterialCount { get; set; }
        public int AttendeeCount { get; set; }
        public DateTime CreatedAt { get; set; }
    }
}
